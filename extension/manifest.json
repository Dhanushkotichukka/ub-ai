{
  "manifest_version": 3,
  "name": "OwlCoder AI Tracker",
  "version": "1.0.0",
  "description": "Automatically sync LeetCode and GeeksforGeeks submissions to your OwlCoder AI growth dashboard.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "declarativeContent"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.geeksforgeeks.org/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*/submissions*", "https://leetcode.com/problems/*"],
      "js": ["content_leetcode.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://*.geeksforgeeks.org/problems/*"],
      "js": ["content_gfg.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
