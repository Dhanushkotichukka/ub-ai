# ==============================
# OwlCoder AI — Production Environment Variables
# ==============================

# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority

# Security / Authentication (Generate strong random strings for these)
# You can run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate these
JWT_SECRET=your_production_jwt_secret_here
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=your_production_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=90d

# Google OAuth (For production app)
GOOGLE_CLIENT_ID=your_production_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_production_google_client_secret

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_production_email@example.com
EMAIL_PASS=your_production_app_password
EMAIL_FROM="OwlCoder AI" <noreply@yourdomain.com>

# AI Integration
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here # Optional fallback

# Frontend URLs for CORS
# Make sure to include both your custom domains and the render.com domain if applicable
CLIENT_URL=https://your-production-domain.com
FLUTTER_WEB_URL=https://your-flutter-web-domain.com

# Firebase Admin SDK (For Push Notifications)
# Note: Private key must be formatted with newline characters correctly
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-firebase-project-id.iam.gserviceaccount.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Third-Party APIs (Usually public endpoints)
LEETCODE_GRAPHQL_URL=https://leetcode.com/graphql
CODEFORCES_API_URL=https://codeforces.com/api
