# ==============================
# OwlCoder AI — Environment Variables
# ==============================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/owlcoder?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=90d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (Nodemailer — Gmail or SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=OwlCoder AI <noreply@owlcoder.ai>

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
FLUTTER_WEB_URL=http://localhost:54321

# Firebase Admin (for FCM push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# LeetCode GraphQL (no key needed — public API)
LEETCODE_GRAPHQL_URL=https://leetcode.com/graphql

# Codeforces API
CODEFORCES_API_URL=https://codeforces.com/api
